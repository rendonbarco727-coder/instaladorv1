[Unit]
Description=BMO Music Autostart (cloudflared + Node)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ruben
WorkingDirectory=/home/ruben/wa-ollama
ExecStart=/usr/bin/python3 /home/ruben/wa-ollama/bmo_autostart.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bmo-autostart

[Install]
WantedBy=multi-user.target
